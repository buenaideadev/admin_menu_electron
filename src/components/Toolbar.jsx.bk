export default function Toolbar({ onAddDepartment, onSave }) {
  return (
    <div style={{
      height: 60,
      borderBottom: '1px solid #ccc',
      display: 'flex',
      alignItems: 'center',
      padding: '0 20px',
      gap: 10,
      background: '#fafafa'
    }}>
      <button onClick={onAddDepartment}>
        ➕ Departamento
      </button>

      <button onClick={onSave}>
        💾 Guardar
      </button>
    </div>
  )
}